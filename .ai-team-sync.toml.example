# ai-team-sync team configuration
# Check this file into your repo so all team members share the same settings.

[server]
# URL of the shared ai-team-sync server
url = "http://localhost:8400"

[locks]
# "advisory" = warn on overlap, "exclusive" = block commits on overlap
default_mode = "advisory"
# Hours before a lock auto-expires (prevents forgotten locks)
ttl_hours = 8
# Show a warning when starting a session that overlaps with an existing lock
warn_on_overlap = true

[notifications]
# Which events trigger team notifications
events = [
    "session.started",
    "session.completed",
    "lock.conflict",
    "lock.expired",
    "decision.logged",
]

[session]
# Auto-detect agent type from environment (CLAUDE_CODE, CURSOR, COPILOT, etc.)
auto_detect_agent = true
# Auto-create scope locks when starting a session
auto_lock = true

[approval]
# Auto-approve override requests containing these keywords
auto_approve_keywords = ["urgent", "security", "hotfix", "critical"]
# Auto-deny override requests containing these keywords (higher priority)
auto_deny_keywords = ["breaking change", "major refactor"]
# Action when override request times out: "expire" or "auto-deny"
timeout_action = "expire"
# Use LLM to evaluate justifications (requires API key, experimental)
llm_evaluate = false
